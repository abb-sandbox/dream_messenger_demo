# Windows/Linux Build Folders
/windows/flutter/ephemeral/
/linux/flutter/ephemeral/
.cmake/

# Visual Studio / CMake specific
CMakeSettings.json
Visual.Config
.vs/

# Better Desktop generated file coverage
**/linux/flutter/generated_*/
**/windows/flutter/generated_*/
**/macos/Flutter/Generated*/

# Just in case, ignore the whole build directory at the root
build/


# -------------------------------------------------------------------------
# Android (Kotlin DSL & Gradle)
# -------------------------------------------------------------------------
# We KEEP .kts files, but ignore the local machine artifacts
.gradle/
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/local.properties
/android/key.properties
/android/app/src/main/res/raw/google-services.json

# Ignore generated Kotlin/Gradle files
.kotlin/
*.kotlin_module

# If using specific keystores for signing
*.keystore
*.jks

